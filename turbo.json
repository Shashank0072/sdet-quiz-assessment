{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:perf": {
      "cache": false,
      "inputs": [
        "package.json",
        "scripts/**",
        "src/**",
        "../../apps/api/src/**",
        "../../packages/workers/src/**"
      ],
      "outputs": ["dist/perf-results.json"],
      "env": ["API_BASE_URL", "DATABASE_URL", "REDIS_URL", "PORT"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
